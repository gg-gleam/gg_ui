<div class="cn-avatar-group group/avatar-group" data-slot="avatar-group">
  <span class="cn-avatar cn-avatar-size-default cn-avatar-shape-circle group/avatar" data-avatar-root data-shape="circle" data-size="default" data-slot="avatar">
    <span class="cn-avatar-fallback" data-slot="avatar-fallback">
      CN
    </span>
  </span>
  <div class="cn-avatar-group-count" data-slot="avatar-group-count">
    +3
  </div>
</div>
